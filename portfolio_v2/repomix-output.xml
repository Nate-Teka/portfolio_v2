    }
  }
  --font-display: "Space Grotesk", sans-serif;
  --font-body: "Outfit", sans-serif;
  --font-mono: "JetBrains Mono", monospace;
}

:root {
  --background: #ffffff;
  --foreground: #171717;
  --bg: #14181a;
  --bg-2: #1a201f;
  --bg-nav: #151a1c;
  --panel: #1e2625;
